{
  "name": "reComputer R1000 Configurator",
  "version": "0.6.7",
  "slug": "recomputer_r1000_configurator_addon",
  "description": "Boot-time verify and repair for reComputer R1000 RS485, LED and buzzer setup.",
  "arch": ["armhf", "armv7", "aarch64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "devicetree": true,
  "ingress": false,
  "services": ["mqtt:want"],
  "stage": "experimental",
  "apparmor": false,
  "privileged": ["SYS_ADMIN"],
  "full_access": true,
  "url": "https://wiki.seeedstudio.com/recomputer_r/",
  "options": {
    "board_version": "v1_1",
    "strict_profile_validation": false,
    "boot_partition_override": "",
    "emit_homeassistant_config_snippet": true,
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "mqtt_topic_prefix": "recomputer_r1000",
    "mqtt_discovery_prefix": "homeassistant",
    "mqtt_enable_discovery": true,
    "mqtt_auto_anonymous_fallback": true,
    "enable_rs485": true,
    "enable_recomputer_r100x_overlay": true,
    "enable_rs485_de_control": false,
    "enable_led_check": true,
    "led_self_test": false,
    "enable_buzzer_check": true,
    "buzzer_self_test": false,
    "check_interval_sec": 60
  },
  "schema": {
    "board_version": "list(v1_0|v1_1|auto)",
    "strict_profile_validation": "bool",
    "boot_partition_override": "str",
    "emit_homeassistant_config_snippet": "bool",
    "mqtt_host": "str",
    "mqtt_port": "port",
    "mqtt_username": "str",
    "mqtt_password": "password",
    "mqtt_topic_prefix": "str",
    "mqtt_discovery_prefix": "str",
    "mqtt_enable_discovery": "bool",
    "mqtt_auto_anonymous_fallback": "bool",
    "enable_rs485": "bool",
    "enable_recomputer_r100x_overlay": "bool",
    "enable_rs485_de_control": "bool",
    "enable_led_check": "bool",
    "led_self_test": "bool",
    "enable_buzzer_check": "bool",
    "buzzer_self_test": "bool",
    "check_interval_sec": "int(15,3600)"
  }
}
